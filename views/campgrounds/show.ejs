<% layout('layouts/boilerplate') %>

    <div class="row">
        <div class="col-6 offset-3">
            <div class="card">
                <img src="<%= campground.image %>" class="card-img-top" alt="...">
                <div class="card-body">
                    <h5 class="card-title">
                        <%= campground.title %>
                    </h5>
                    <p class="card-text">
                        <%= campground.description %>
                    </p>
                </div>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">
                        <%= campground.price %>
                    </li>
                    <li class="list-group-item">
                        <%= campground.location %>
                    </li>
                </ul>
                <div class="card-body">
                    <a class="btn btn-info" href="/campgrounds/<%= campground._id %>/edit">Edit</a>
                    <a class="btn btn-primary" href="/campgrounds" class="card-link">All Campgrounds</a>
                    <form class="d-inline" action="/campgrounds/<%= campground._id %>?_method=DELETE" method="post">
                        <button class="btn btn-danger">Delete</button>
                    </form>
                </div>
            </div>

            <h2 class="mt-3">Leave a Review</h2>
            <form action="/campgrounds/<%= campground._id %>/review" method="POST" class="mb-3">
                <div class="mb-3">
                    <label class='form-label' for="rating">Rating</label>
                    <input class='form-range' type='range' name="review[rating]" id="rating" min="1" max="5">
                </div>
                <div class="mb-3">
                    <label class='form-label' for="body">Review</label>
                    <textarea class='form-control' name="review[body]" id="body" cols="30" rows="4"></textarea>
                </div>
                <button class="btn btn-success">Submit</button>
            </form>
        </div>
    </div>