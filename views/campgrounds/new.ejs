<% layout('layouts/boilerplate') %>
    <div class="row">
        <h1 class="text-center">New Campground</h1>
        <div class="col-6 offset-3">
            <form action="/campgrounds" method="POST">
                <div class="mb-3">
                    <label class="form-label" for="title">Enter title:</label>
                    <input class="form-control" type="text" id="title" name="campground[title]">
                </div>
                <div class="mb-3">
                    <label class="form-label" for="location">Enter Location:</label>
                    <input class="form-control" type="text" id="location" name="campground[location]">
                </div>
                <div class="mb-3">
                    <label class="form-label" for="image">Enter Image URL:</label>
                    <input class="form-control" type="text" id="image" name="campground[image]">
                </div>
                <div class="mb-3">
                    <label class="form-label" for="price">Enter price:</label>
                    <input class="form-control" type="Number" id="price" name="campground[price]">
                </div>
                <div>
                    <button class="btn btn-success">Add</button>
                    <a href="/campgrounds" class="btn btn-danger">Cancel</a>
                </div>
            </form>

        </div>
    </div>